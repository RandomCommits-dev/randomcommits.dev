---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CommitGenerator from '../components/CommitGenerator.tsx';

const repos = (await getCollection('repos')).sort(
	(a, b) => +new Date(b.data.updatedAt) - +new Date(a.data.updatedAt),
);

const categories = [
	{ label: 'Flagship', test: (n: string) => !/^(lab|template|study)-/.test(n) },
	{ label: 'Experiments', test: (n: string) => n.startsWith('lab-') },
	{ label: 'Templates', test: (n: string) => n.startsWith('template-') },
	{ label: 'Learning', test: (n: string) => n.startsWith('study-') },
];

const grouped = categories
	.map((c) => ({ ...c, repos: repos.filter((r) => c.test(r.data.name)) }))
	.filter((g) => g.repos.length > 0);

// Shown only when the org has no qualifying repos yet.
const fallback = [
	{ name: 'Flagship projects', desc: 'Built to last. The ones we are proud of.', tag: 'no prefix' },
	{ name: 'lab-*', desc: 'Experiments & vibe-coding sessions.', tag: 'experiment' },
	{ name: 'template-*', desc: 'Starter templates we reach for.', tag: 'template' },
	{ name: 'study-*', desc: 'Learning in public.', tag: 'study' },
];
---

<BaseLayout>
	<section class="hero">
		<p class="eyebrow">🌱 randomcommits.dev</p>
		<h1>Welcome to the garden.</h1>
		<p class="lede">
			Our landing page and digital garden for all the random,
			vibe-driven coding projects we work on. Some things here are
			polished. Some are half-finished sketches. All of them are
			commits we felt like making.
		</p>
		<CommitGenerator client:load />
	</section>

	{repos.length > 0 ? (
		grouped.map((group) => (
			<section class="grid-section">
				<h2>{group.label}</h2>
				<div class="grid">
					{group.repos.map((r) => (
						<a class="tile" href={r.data.homepage || r.data.url}>
							<h3>{r.data.name}</h3>
							<p>{r.data.description || 'No description yet.'}</p>
							<span class="tile-meta">
								{r.data.language && <span class="badge">{r.data.language}</span>}
								{r.data.stars > 0 && <span class="badge">★ {r.data.stars}</span>}
							</span>
						</a>
					))}
				</div>
			</section>
		))
	) : (
		<section class="grid-section">
			<h2>What you'll find</h2>
			<div class="grid">
				{fallback.map((p) => (
					<article class="tile">
						<h3>{p.name}</h3>
						<p>{p.desc}</p>
						<span class="badge">{p.tag}</span>
					</article>
				))}
			</div>
		</section>
	)}
</BaseLayout>
