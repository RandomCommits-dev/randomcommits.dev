---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const notes = await getCollection('notes', ({ data }) => !data.draft);
	return notes.map((note) => ({
		params: { id: note.id },
		props: { note },
	}));
}

const { note } = Astro.props;
const { Content } = await render(note);

const growthEmoji: Record<string, string> = {
	seedling: '🌱',
	budding: '🌿',
	evergreen: '🌳',
};

const fmt = (d: Date) =>
	d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
	title={`${note.data.title} · randomcommits.dev`}
	description={note.data.description ?? note.data.title}
>
	<article class="prose">
		<p class="eyebrow"><a href="/garden">← Garden</a></p>
		<h1>{note.data.title}</h1>
		<p class="note-meta">
			<span>{growthEmoji[note.data.growth]} {note.data.growth}</span>
			<span>·</span>
			<span>{fmt(note.data.pubDate)}</span>
			{note.data.updatedDate && <span>· updated {fmt(note.data.updatedDate)}</span>}
			{note.data.tags.map((t) => <span class="badge">#{t}</span>)}
		</p>
		<Content />
	</article>
</BaseLayout>
