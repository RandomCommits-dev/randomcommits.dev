---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'randomcommits.dev · digital garden',
	description = 'A landing page and digital garden for random, vibe-driven coding projects at randomcommits.dev.',
} = Astro.props;

const nav = [
	{ href: '/', label: 'Home' },
	{ href: '/garden', label: 'Garden' },
	{ href: '/lab', label: 'Labs' },
	{ href: 'https://github.com/RandomCommits-dev', label: 'GitHub', external: true },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
	href === '/' ? path === '/' : path.startsWith(href);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link
			rel="alternate"
			type="application/rss+xml"
			title="randomcommits.dev garden"
			href={new URL('rss.xml', Astro.site)}
		/>
		<title>{title}</title>
	</head>
	<body>
		<header class="site-nav">
			<a class="brand" href="/">🌱 randomcommits.dev</a>
			<nav>
				{nav.map((item) => (
					<a
						href={item.href}
						class:list={['nav-link', { active: !item.external && isActive(item.href) }]}
						{...item.external ? { target: '_blank', rel: 'noopener' } : {}}
					>
						{item.label}
					</a>
				))}
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer>
			<a href="https://github.com/RandomCommits-dev">GitHub</a>
			<span>·</span>
			<a href="/rss.xml">RSS</a>
			<span>·</span>
			<span>Tended irregularly. Watered with curiosity. 🌿</span>
		</footer>

		<style is:global>
			:root {
				--bg: #0d1117;
				--surface: #161b22;
				--border: #30363d;
				--text: #e6edf3;
				--muted: #9198a1;
				--accent: #3fb950;
				--accent-soft: rgba(63, 185, 80, 0.12);
			}

			* { box-sizing: border-box; }

			html { color-scheme: dark; }

			body {
				margin: 0;
				background:
					radial-gradient(1200px 600px at 50% -10%, var(--accent-soft), transparent),
					var(--bg);
				color: var(--text);
				font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
				line-height: 1.6;
				min-height: 100vh;
			}

			.site-nav {
				max-width: 880px;
				margin: 0 auto;
				padding: 1.5rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 1rem;
				flex-wrap: wrap;
			}

			.brand {
				color: var(--text);
				font-weight: 600;
				text-decoration: none;
				font-size: 1rem;
			}

			.site-nav nav {
				display: flex;
				gap: 1.25rem;
			}

			.nav-link {
				color: var(--muted);
				text-decoration: none;
				font-size: 0.95rem;
				transition: color 0.15s ease;
			}

			.nav-link:hover { color: var(--text); }
			.nav-link.active { color: var(--accent); }

			main {
				max-width: 880px;
				margin: 0 auto;
				padding: 3rem 1.5rem 3rem;
			}

			.eyebrow {
				color: var(--accent);
				font-weight: 600;
				letter-spacing: 0.02em;
				margin: 0 0 0.5rem;
			}

			h1 {
				font-size: clamp(2.5rem, 6vw, 4rem);
				line-height: 1.05;
				margin: 0 0 1rem;
				letter-spacing: -0.02em;
			}

			.lede {
				color: var(--muted);
				font-size: 1.15rem;
				max-width: 60ch;
				margin: 0 0 2rem;
			}

			.commit-card {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 14px;
				padding: 1.5rem;
				display: flex;
				flex-direction: column;
				gap: 1rem;
				align-items: flex-start;
			}

			.commit-message {
				font-family: ui-monospace, 'SFMono-Regular', 'Cascadia Code', Menlo, monospace;
				font-size: 1.05rem;
				color: var(--text);
				background: #0d1117;
				border: 1px solid var(--border);
				border-radius: 8px;
				padding: 0.75rem 1rem;
				width: 100%;
				word-break: break-word;
			}

			.commit-button {
				background: var(--accent);
				color: #0d1117;
				font-weight: 600;
				font-size: 0.95rem;
				border: none;
				border-radius: 8px;
				padding: 0.65rem 1.1rem;
				cursor: pointer;
				transition: transform 0.05s ease, filter 0.15s ease;
			}

			.commit-button:hover { filter: brightness(1.08); }
			.commit-button:active { transform: translateY(1px); }

			.commit-count {
				color: var(--muted);
				font-size: 0.9rem;
				margin: 0;
			}

			.grid-section { margin-top: 4rem; }

			h2 {
				font-size: 1.5rem;
				margin: 0 0 1.5rem;
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1rem;
			}

			.tile {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 12px;
				padding: 1.25rem;
				transition: border-color 0.15s ease, transform 0.15s ease;
			}

			a.tile {
				display: block;
				text-decoration: none;
				color: inherit;
			}

			.tile:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
			}

			.tile-meta {
				display: flex;
				gap: 0.4rem;
				flex-wrap: wrap;
			}

			.tile h3 {
				margin: 0 0 0.4rem;
				font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
				color: var(--accent);
				font-size: 1.05rem;
			}

			.tile p {
				margin: 0 0 0.75rem;
				color: var(--muted);
				font-size: 0.95rem;
			}

			.badge {
				display: inline-block;
				font-size: 0.75rem;
				color: var(--accent);
				background: var(--accent-soft);
				border-radius: 999px;
				padding: 0.15rem 0.6rem;
			}

			/* Garden list */
			.note-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}

			.note-item {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 12px;
				padding: 1.1rem 1.25rem;
				transition: border-color 0.15s ease;
			}

			.note-item:hover { border-color: var(--accent); }

			.note-item a {
				color: var(--text);
				text-decoration: none;
				font-weight: 600;
			}

			.note-item a:hover { color: var(--accent); }

			.note-meta {
				color: var(--muted);
				font-size: 0.85rem;
				margin-top: 0.25rem;
				display: flex;
				gap: 0.6rem;
				align-items: center;
				flex-wrap: wrap;
			}

			/* Article / prose */
			.prose {
				max-width: 70ch;
			}

			.prose :where(p, ul, ol, blockquote) {
				color: var(--text);
			}

			.prose a { color: var(--accent); }

			.prose code {
				font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 6px;
				padding: 0.1rem 0.35rem;
				font-size: 0.9em;
			}

			.prose pre {
				background: #0d1117;
				border: 1px solid var(--border);
				border-radius: 10px;
				padding: 1rem;
				overflow-x: auto;
			}

			.prose pre code {
				background: none;
				border: none;
				padding: 0;
			}

			footer {
				max-width: 880px;
				margin: 4rem auto 0;
				padding: 1.5rem;
				border-top: 1px solid var(--border);
				color: var(--muted);
				font-size: 0.9rem;
				display: flex;
				gap: 0.6rem;
				flex-wrap: wrap;
				align-items: center;
			}

			footer a { color: var(--accent); text-decoration: none; }
			footer a:hover { text-decoration: underline; }

			@media (prefers-reduced-motion: reduce) {
				* { transition: none !important; }
			}
		</style>
	</body>
</html>
